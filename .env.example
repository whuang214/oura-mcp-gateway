# Copy this file to .env before running the server. At startup, the application
# reads only ./.env from its working directory. It never reads this template,
# Windows or shell environment variables, parent directories, or Codex env_vars.
# Never commit the populated .env file.

# Start safely with deterministic sample data. Change to live after adding your
# own Oura OAuth application credentials below.
OURA_MODE=fixture

# Live authorization. Leave OURA_ACCESS_TOKEN blank when using the refreshable
# authorization-code flow. Never commit real values.
OURA_ACCESS_TOKEN=
OURA_CLIENT_ID=
OURA_CLIENT_SECRET=
OURA_REDIRECT_URI=http://localhost:8765/callback
OURA_TOKEN_FILE=.private/tokens.json

# Official Oura endpoints and requested scopes.
OURA_AUTHORIZE_URL=https://cloud.ouraring.com/oauth/authorize
OURA_TOKEN_URL=https://api.ouraring.com/oauth/token
OURA_API_BASE_URL=https://api.ouraring.com/v2/usercollection
OURA_SCOPES=daily workout session spo2

# Runtime behavior. Replace Etc/UTC with your IANA home timezone before live
# use, for example America/Denver or Europe/London.
OURA_HOME_TIMEZONE=Etc/UTC
OURA_HTTP_TIMEOUT_SECONDS=20
OURA_OPERATION_TIMEOUT_SECONDS=105
OURA_MAX_RETRIES=3
OURA_BACKOFF_BASE_SECONDS=0.5
OURA_MAX_RETRY_AFTER_SECONDS=30
OURA_MAX_RANGE_DAYS=90
OURA_TOKEN_REFRESH_SKEW_SECONDS=60
OURA_ENABLE_RESILIENCE=false
OURA_ENABLE_SPO2=true

# Fixture mode. A blank directory uses the sample data packaged with the app.
OURA_FIXTURE_DIR=
OURA_FIXTURE_TODAY=2026-07-11

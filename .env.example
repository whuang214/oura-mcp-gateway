# Copy this file to .env, then paste the client ID and secret from your own
# Oura application (https://cloud.ouraring.com/oauth/applications).
# The server reads only ./.env in its working directory — never shell or
# Windows environment variables. Never commit the populated .env file.

OURA_CLIENT_ID=
OURA_CLIENT_SECRET=

# Optional but recommended: replace Etc/UTC with your IANA timezone, for
# example America/New_York or Europe/London, so "today" matches your clock.
OURA_HOME_TIMEZONE=Etc/UTC

# ---------------------------------------------------------------------------
# Everything below is optional. Defaults are shown; uncomment a line only if
# you need to change it. See docs/configuration.md for the full list.
# ---------------------------------------------------------------------------

# Try the server without an Oura account using packaged sample data.
#OURA_MODE=fixture

# Paste a ready-made OAuth bearer token instead of running the authorize
# flow. It cannot be refreshed, so prefer `uv run oura-oauth authorize`.
#OURA_ACCESS_TOKEN=

# Must exactly match the redirect URI registered on your Oura application.
#OURA_REDIRECT_URI=http://localhost:8765/callback

# Where refreshable OAuth tokens are stored, relative to this file.
#OURA_TOKEN_FILE=.private/tokens.json

# Data categories to request. To retrieve SpO2, add spo2 to the scopes AND
# set OURA_ENABLE_SPO2=true — each requires the other.
#OURA_SCOPES=daily workout session
#OURA_ENABLE_SPO2=false

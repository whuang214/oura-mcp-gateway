# Never commit a populated .env file. For Codex desktop, prefer forwarding a
# user environment variable with config.toml `env_vars`, not a plaintext env map.
OURA_MODE=fixture

# Live mode: use either an access token, or OAuth client credentials plus a
# securely stored token file created by the authorization-code flow.
OURA_ACCESS_TOKEN=
OURA_CLIENT_ID=
OURA_CLIENT_SECRET=
OURA_REDIRECT_URI=http://127.0.0.1:8765/callback
OURA_TOKEN_FILE=

# OAuth/API configuration. Defaults are shown for clarity.
OURA_AUTHORIZE_URL=https://cloud.ouraring.com/oauth/authorize
OURA_TOKEN_URL=https://api.ouraring.com/oauth/token
OURA_API_BASE_URL=https://api.ouraring.com/v2/usercollection
OURA_SCOPES=daily workout session

# Runtime behavior.
OURA_HOME_TIMEZONE=America/Denver
OURA_HTTP_TIMEOUT_SECONDS=20
OURA_MAX_RETRIES=3
OURA_BACKOFF_BASE_SECONDS=0.5
OURA_MAX_RETRY_AFTER_SECONDS=30
OURA_MAX_RANGE_DAYS=90
OURA_ENABLE_SPO2=false
OURA_FIXTURE_DIR=
OURA_FIXTURE_TODAY=2026-07-11
